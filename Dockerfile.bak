# --------- Builder Stage ---------
# For faster rebuilds: use BuildKit (DOCKER_BUILDKIT=1) so uv cache is reused.
FROM ghcr.io/astral-sh/uv:python3.11-bookworm-slim AS builder

# Set environment variables for uv
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
ENV UV_CACHE_DIR=/tmp/uv-cache

WORKDIR /app

# Copy dependency files first (for better layer caching)
# README.md required by pyproject.toml for hatch build
COPY pyproject.toml uv.lock README.md ./
COPY beampipe-wallaby /app/beampipe-wallaby

# Install dependencies first (for better layer caching)
# Cache mount reuses uv cache between builds (requires: DOCKER_BUILDKIT=1)
# Using sharing=locked to prevent permission conflicts when multiple builds run in parallel
RUN --mount=type=cache,target=/tmp/uv-cache,sharing=locked \
    uv sync --locked --no-install-project --all-groups --extra wallaby

# Copy only the source needed for the package (avoids calibration files, .venv, etc.)
COPY src /app/src

# Install the project in non-editable mode
# Include dev dependencies for testing
RUN --mount=type=cache,target=/tmp/uv-cache,sharing=locked \
    uv sync --locked --no-editable --all-groups --extra wallaby

# --------- Final Stage ---------
FROM python:3.11-slim-bookworm

# Create a non-root user for security
RUN groupadd --gid 1000 app \
    && useradd --uid 1000 --gid app --shell /bin/bash --create-home app

# Copy the virtual environment from the builder stage
COPY --from=builder --chown=app:app /app/.venv /app/.venv

# Ensure the virtual environment is in the PATH
ENV PATH="/app/.venv/bin:$PATH"

# Switch to the non-root user
USER app

# Set the working directory
WORKDIR /code

# -------- replace with comment to run with gunicorn --------
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
# CMD ["gunicorn", "app.main:app", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "-b", "0.0.0.0:8000"]
