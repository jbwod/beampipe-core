    "nodeDataArray": [
        {
            "category": "PyFuncApp",
            "categoryType": "Application",
            "color": "#0059a5",
            "comment": "",
            "commitHash": "435965f",
            "dataHash": "83264c2930d04314860785d5395539788fbd510809b6fb49a6ad704f92481eb2",
            "description": "Generic entry point for manifest-driven graphs. Input: manifest file path (from File drop) OR inline JSON (set at submit so the manifest is embedded in the graph \u2014 no second file upload). Output: raw manifest bytes for downstream nodes (parse, parset, download, etc.).",
            "drawOrderHint": 0,
            "fields": [
                {
                    "defaultValue": "beampipe_ingest",
                    "description": "Python function name (must match the function defined in func_code).",
                    "encoding": "pickle",
                    "id": "3e8927be-6c53-4d57-b4a3-5424aa6935c9",
                    "name": "func_name",
                    "options": [],
                    "parameterType": "ComponentParameter",
                    "positional": false,
                    "precious": false,
                    "readonly": false,
                    "type": "String",
                    "usage": "NoPort",
                    "value": "beampipe_ingest"
                },
                {
                    "defaultValue": "def beampipe_ingest(manifest_path: str) -> bytes:\n    \"\"\"Manifest path (file path) or inline JSON string. When embedded at submit, no file upload needed.\"\"\"\n    if not manifest_path:\n        return b'{}'\n    s = manifest_path.strip()\n    if s.startswith('{') and s.endswith('}'):\n        return s.encode('utf-8')\n    with open(manifest_path, 'rb') as f:\n        return f.read()",
                    "description": "Input: file path (from File drop) or inline JSON string (set at submit so manifest is inside the graph, no second file).",
                    "encoding": "pickle",
                    "id": "52afb00b-e2bb-4602-b7dc-896d69a6124c",
                    "name": "func_code",
                    "options": [],
                    "parameterType": "ComponentParameter",
                    "positional": false,
                    "precious": false,
                    "readonly": false,
                    "type": "String",
                    "usage": "NoPort",
                    "value": "def beampipe_ingest(manifest_path: str) -> bytes:\n    \"\"\"Manifest path (file path) or inline JSON string. When embedded at submit, no file upload needed.\"\"\"\n    if not manifest_path:\n        return b'{}'\n    s = manifest_path.strip()\n    if s.startswith('{') and s.endswith('}'):\n        return s.encode('utf-8')\n    with open(manifest_path, 'rb') as f:\n        return f.read()"
                },
