            "description": "Generic entry point for manifest-driven graphs. Input: manifest file path (from File drop) OR inline JSON (set at submit so the manifest is embedded in the graph — no second file upload). Output: raw manifest bytes for downstream nodes (parse, parset, download, etc.).",
            "fields": [
                {
                    "defaultValue": "beampipe_ingest",
                    "description": "Python function name (must match the function defined in func_code).",
                    "encoding": "pickle",
                    "id": "d5ba91c6-9bcd-471d-b5e8-e875f207f83b",
                    "name": "func_name",
                    "options": [],
                    "parameterType": "ComponentParameter",
                    "positional": false,
                    "precious": false,
                    "readonly": false,
                    "type": "String",
                    "usage": "NoPort",
                    "value": "beampipe_ingest"
                },
                {
                    "defaultValue": "def beampipe_ingest(manifest_path: str) -> bytes:\n    \"\"\"When embedded at submit, no file upload needed.\"\"\"\n    if not manifest_path:\n        return b'{}'\n    s = manifest_path.strip()\n    if s.startswith('{') and s.endswith('}'):\n        return s.encode('utf-8')\n    with open(manifest_path, 'rb') as f:\n        return f.read()",
                    "description": "Input: file path (from File drop) or inline JSON string (set at submit so manifest is inside the graph, no second file).",
                    "encoding": "pickle",
                    "id": "141bdbec-c515-4f72-a9ca-7c4f86bad2f5",
                    "name": "func_code",
                    "options": [],
                    "parameterType": "ComponentParameter",
                    "positional": false,
                    "precious": false,
                    "readonly": false,
                    "type": "String",
                    "usage": "NoPort",
                    "value": "def beampipe_ingest(manifest_path: str) -> bytes:\n    \"\"\"When embedded at submit, no file upload needed.\"\"\"\n    if not manifest_path:\n        return b'{}'\n    s = manifest_path.strip()\n    if s.startswith('{') and s.endswith('}'):\n        return s.encode('utf-8')\n    with open(manifest_path, 'rb') as f:\n        return f.read()"
                },
